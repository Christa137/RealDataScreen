{
  "name": "datascreen",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "DataScreen 数据大屏：一个基于 Vue 3 的纯前端数据可视化大屏项目。",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint . && stylelint \"src/**/*.{css,vue}\"",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "keywords": [
    "vue",
    "dashboard",
    "echarts",
    "big-screen",
    "data-visualization"
  ],
  "license": "MIT"
}
