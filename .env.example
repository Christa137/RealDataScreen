# MySQL connection (used by server/index.js and scripts/load_data_to_mysql.py)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=datascreen

# Frontend data source: 'mock' | 'api'
# mock  = use realtime simulator (no MySQL required)
# api   = fetch real data from backend API + MySQL
VITE_DATA_SOURCE=api
